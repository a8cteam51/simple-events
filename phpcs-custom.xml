<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="Simple Events Custom Rules" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">

	<description>Custom PHPCS configuration for Simple Events plugin with prefix validation fix</description>

	<!-- Include the Team51 configuration -->
	<rule ref="vendor/a8cteam51/team51-configs/phpcs.xml"/>

	<!-- Completely exclude the original WordPress prefix validation rule -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>
	</rule>

	<!-- Include our custom legacy sniff that allows 3-character prefixes -->
	<rule ref="./phpcs/ruleset.xml"/>

	<!-- Configure our custom prefix validation with 3-character prefixes -->
	<rule ref="SimpleEvents.NamingConventions.PrefixAllGlobalsLegacy">
		<properties>
			<property name="prefixes" type="array">
				<element value="se_"/>
				<element value="SE_"/>
				<element value="simple_events_"/>
				<element value="SimpleEvents"/>
			</property>
		</properties>
	</rule>

	<!-- Exclude custom sniff directory from standard checks -->
	<exclude-pattern>*/phpcs/Sniffs/*</exclude-pattern>

</ruleset>
